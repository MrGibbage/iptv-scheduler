# Copy to .env (in this directory) and fill in real values. Never commit .env.

PORT=4000
DB_PATH=./data/dev.sqlite

# The iptv-recorder base URL/API key are set via the Settings page (or
# PUT /config/recorder) now, not here — see PLAN.md "EPG Ingestion".

# Encrypts the recorder API key at rest (server/src/crypto.ts).
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=
